# Copy this file to .env.local and fill in the values you want.
# .env.local is gitignored — keep your API key private.

# Required for the AI Scan feature.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. Override the Gemini base URL to point at a proxy that mirrors the
# Google REST API (same path /v1beta/models/<model>:generateContent and same
# ?key= auth). Useful for corporate / Data-Annotation-style proxies.
# Leave unset to use Google directly.
# GOOGLE_GEMINI_BASE_URL=https://app.dataannotation.tech/api/llm_proxy/gemini

# Set to 1 to show the camera Scan FAB on the Count screen.
# Without this flag, the feature is invisible and the base counting flow is untouched.
NEXT_PUBLIC_AI_SCAN_ENABLED=1

# Set to 1 to bypass Gemini and return canned matches.
# Useful for UI testing without burning your free-tier quota.
# SCAN_MOCK=1

# When building the iOS app (npm run build:static), point the scan API at
# wherever you've deployed the route handler (e.g. Vercel). Leave unset for
# normal `npm run dev` — the fetch will be relative to the page origin.
# NEXT_PUBLIC_API_BASE=https://your-app.vercel.app

# Cross-device sync (Supabase). Leave BOTH blank to run fully local (no sync,
# IndexedDB only). When set, item/session/count changes sync across every
# device on the same account. See SUPABASE_SETUP.md for the one-time setup.
# NOTE: these are NEXT_PUBLIC_ (compiled into the client), so changing them on
# Vercel requires a redeploy to take effect.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
